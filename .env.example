# Copy to .env.local and fill in. Also set these in your Vercel project
# (Project → Settings → Environment Variables). Both are public by design —
# they ship to the browser — so keep the service_role key out of here entirely.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
